# ─────────────────────────────────────────────────────────────────────────────
# Agentic Customer Support Resolution Engine — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure OpenAI ─────────────────────────────────────────────────────────────
# Endpoint of your Azure OpenAI resource (include trailing slash)
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/

# API key from: Azure Portal → OpenAI resource → Keys and Endpoint
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>

# API version to use with Azure OpenAI
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Name of the deployed chat model (e.g. gpt-4o, gpt-35-turbo)
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Name of the deployed embedding model
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# ── Azure AI Search ───────────────────────────────────────────────────────────
# Endpoint of your Azure AI Search service
AZURE_SEARCH_ENDPOINT=https://<your-search-service-name>.search.windows.net

# Admin key from: Azure Portal → AI Search → Keys
AZURE_SEARCH_KEY=<your-azure-search-admin-key>

# Index name that holds the support knowledge base
AZURE_SEARCH_INDEX=support-kb-index

# ── Azure Cosmos DB ───────────────────────────────────────────────────────────
# Endpoint of your Cosmos DB account
AZURE_COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/

# Primary key from: Azure Portal → Cosmos DB → Keys
AZURE_COSMOS_KEY=<your-cosmos-db-primary-key>

# Cosmos DB database name (created automatically if it doesn't exist)
AZURE_COSMOS_DB=support_db

# Cosmos DB container name used to store conversation checkpoints
AZURE_COSMOS_CONTAINER=conversations

# ── Azure Application Insights ────────────────────────────────────────────────
# Connection string from: Azure Portal → Application Insights → Overview
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/

# ── Application Settings ──────────────────────────────────────────────────────
# Environment name: development | staging | production
APP_ENV=development

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Max number of feedback-loop retries before forced escalation
MAX_RETRY_COUNT=2

# Severity level that triggers automatic human escalation: low | medium | high
ESCALATION_SEVERITY_THRESHOLD=high


GROQ_API_KEY=